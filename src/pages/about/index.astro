---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { profile, projects, techStack, text, timeline } from '@/data/profile';

const traits = ['独立开发者', '全栈工程师', '长期写作者', '产品原型爱好者'];
---

<BaseLayout title="关于我" description="关于 LiuForge：独立开发者、全栈工程师和持续写作者">
  <section class="mb-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="glass rounded-2xl p-6">
      <div class="mb-6 flex items-center gap-4">
        <div class="grid h-16 w-16 place-items-center rounded-2xl border border-white/15 bg-white/10 text-xl font-black text-primary">
          LF
        </div>
        <div>
          <h1 class="text-3xl font-black text-white">{profile.name}</h1>
          <p class="mt-1 text-zinc-400">{text(profile.role)}</p>
        </div>
      </div>
      <p class="text-base leading-8 text-zinc-300">{text(profile.headline)}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {traits.map((trait) => (
          <span class="rounded-lg border border-white/10 bg-white/8 px-3 py-2 text-sm text-zinc-200">{trait}</span>
        ))}
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="glass rounded-2xl p-5">
        <p class="text-sm text-zinc-500">Location</p>
        <h2 class="mt-2 text-xl font-extrabold text-white">{text(profile.location)}</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">偏爱能落地的产品、克制但有记忆点的界面，以及能长期积累的内容系统。</p>
      </div>
      <div class="glass rounded-2xl p-5">
        <p class="text-sm text-zinc-500">Now</p>
        <h2 class="mt-2 text-xl font-extrabold text-white">正在做的事</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">{text(profile.status)}</p>
      </div>
      <div class="glass rounded-2xl p-5 sm:col-span-2">
        <p class="text-sm text-zinc-500">Contact</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a href={`mailto:${profile.email}`} class="rounded-lg bg-primary px-4 py-2 text-sm font-bold text-black">邮箱联系</a>
          <a href={profile.github} target="_blank" rel="noopener noreferrer" class="rounded-lg border border-white/10 bg-white/8 px-4 py-2 text-sm font-bold text-zinc-200">GitHub</a>
          <a href={profile.rss} class="rounded-lg border border-white/10 bg-white/8 px-4 py-2 text-sm font-bold text-zinc-200">RSS</a>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-10">
    <div class="mb-5 flex items-end justify-between">
      <div>
        <p class="text-sm font-semibold text-primary">Stack</p>
        <h2 class="mt-2 text-2xl font-black text-white">技术栈</h2>
      </div>
    </div>
    <div class="glass rounded-2xl p-6">
      <div class="flex flex-wrap gap-2">
        {techStack.map((tech) => (
          <span class="rounded-lg border border-white/10 bg-white/8 px-3 py-2 text-sm text-zinc-200">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="grid gap-5 lg:grid-cols-2">
    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-black text-white">精选项目</h2>
      <div class="mt-5 space-y-4">
        {projects.map((project) => (
          <article class="rounded-xl border border-white/10 bg-white/5 p-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-primary">{text(project.type)}</p>
            <h3 class="mt-2 font-extrabold text-white">{project.title}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{text(project.description)}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-black text-white">经历时间线</h2>
      <div class="mt-5 space-y-5">
        {timeline.map((item) => (
          <article class="border-l border-primary/40 pl-4">
            <time class="text-xs font-bold text-primary">{item.year}</time>
            <h3 class="mt-1 font-extrabold text-white">{text(item.title)}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{text(item.description)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
