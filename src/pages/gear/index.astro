---
import BaseLayout from '@/components/layout/BaseLayout.astro';

const gearItems = [
  {
    name: '降噪耳机',
    brand: 'SONY WH-1000XM5',
    desc: '无线降噪耳机，通勤和工作的最佳伴侣。沉浸式音乐体验，让代码更流畅。',
    icon: '🎧',
    gradient: 'from-violet-600/80 to-purple-700/80',
    accent: '#a855f7',
  },
  {
    name: '机械键盘',
    brand: 'NuPhy Air75 V2',
    desc: '矮轴机械键盘，75% 布局。矮红轴手感轻盈，长时间编码不疲劳。',
    icon: '⌨️',
    gradient: 'from-cyan-600/80 to-blue-700/80',
    accent: '#06b6d4',
  },
  {
    name: '游戏鼠标',
    brand: 'Logitech G Pro X Superlight',
    desc: '63g 超轻无线鼠标，HERO 25K 传感器。精准操控，游戏工作两不误。',
    icon: '🖱️',
    gradient: 'from-emerald-600/80 to-teal-700/80',
    accent: '#10b981',
  },
  {
    name: '超宽显示器',
    brand: 'Dell U4025QW',
    desc: '40 英寸 5K 超宽曲面屏。多窗口并行开发，效率翻倍的视觉工作台。',
    icon: '🖥️',
    gradient: 'from-blue-600/80 to-indigo-700/80',
    accent: '#3b82f6',
  },
  {
    name: '主机配置',
    brand: 'DIY PC Build',
    desc: 'i7-14700K + RTX 4080 Super + 64GB DDR5。2TB NVMe 固态，编译速度快如闪电。',
    icon: '🖥',
    gradient: 'from-orange-600/80 to-red-700/80',
    accent: '#f97316',
  },
  {
    name: '显示器挂灯',
    brand: 'BenQ ScreenBar Halo',
    desc: '智能屏幕挂灯，自动调光。护眼灯效，深夜编码的温柔守护。',
    icon: '💡',
    gradient: 'from-amber-500/80 to-yellow-600/80',
    accent: '#f59e0b',
  },
  {
    name: '降噪麦克风',
    brand: 'Shure MV7',
    desc: '动圈麦克风，USB/XLR 双模。会议录音清晰饱满，专业级收音品质。',
    icon: '🎙️',
    gradient: 'from-rose-600/80 to-pink-700/80',
    accent: '#f43f5e',
  },
  {
    name: '人体工学椅',
    brand: 'Herman Miller Embody',
    desc: '顶级人体工学椅，久坐不累。保护颈椎腰椎，程序员最重要的投资。',
    icon: '🪑',
    gradient: 'from-slate-600/80 to-zinc-700/80',
    accent: '#64748b',
  },
  {
    name: '平板设备',
    brand: 'iPad Pro M4 13"',
    desc: '移动办公与设计利器。随航副屏、手绘草稿，拓展工作方式的边界。',
    icon: '📱',
    gradient: 'from-sky-600/80 to-cyan-700/80',
    accent: '#0ea5e9',
  },
];
---

<BaseLayout title="我的装备" description="我的装备 - 数字生活与开发工具">
  <!-- ====== Hero 区域 ====== -->
  <section class="py-12 sm:py-16 text-center">
    <div class="inline-flex items-center gap-3 mb-4">
      <span class="text-4xl">⚙️</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">
      <span class="bg-gradient-to-r from-primary via-cyan-300 to-blue-400 bg-clip-text text-transparent">
        我的装备
      </span>
    </h1>
    <p class="text-zinc-400 text-sm sm:text-base max-w-lg mx-auto leading-relaxed">
      一个极客的数字生活装备清单。好的工具是效率的延伸，也是创作的乐趣所在。
    </p>

    <!-- 装饰线 -->
    <div class="flex items-center justify-center gap-3 mt-6">
      <span class="block h-px w-12 bg-gradient-to-r from-transparent to-zinc-600"></span>
      <span class="text-zinc-600 text-lg">⚡</span>
      <span class="block h-px w-12 bg-gradient-to-l from-transparent to-zinc-600"></span>
    </div>
  </section>

  <!-- ====== 装备卡片网格 ====== -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
    {gearItems.map((item) => (
      <div
        class="group rounded-2xl bg-bg-card border border-zinc-800 hover:border-zinc-600 transition-all duration-300 overflow-hidden flex flex-col"
      >
        {/* 占位图片区域 */}
        <div class={`relative h-48 bg-gradient-to-br ${item.gradient} flex items-center justify-center`}>
          <div class="absolute inset-0 bg-black/20"></div>
          {/* 占位图标 - 替换为实际图片时删除此 div */}
          <div class="relative z-10 w-20 h-20 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center text-5xl">
            {item.icon}
          </div>
          {/* 替换为实际图片：<img src="/gear/xxx.jpg" alt={item.name} class="w-full h-full object-cover" /> */}
          <div class="absolute bottom-3 right-3 z-10">
            <span class="text-[10px] text-white/40 bg-black/30 px-2 py-0.5 rounded-full">图片占位</span>
          </div>
        </div>

        {/* 装备信息 */}
        <div class="p-5 flex flex-col gap-2 flex-1">
          <div class="flex items-start justify-between gap-2">
            <div>
              <h3 class="font-semibold text-zinc-100 group-hover:text-primary transition-colors text-base">
                {item.name}
              </h3>
              <p class="text-xs font-medium mt-0.5" style={`color: ${item.accent}`}>
                {item.brand}
              </p>
            </div>
            <span class="text-xl shrink-0 mt-0.5">{item.icon}</span>
          </div>
          <p class="text-zinc-500 text-xs leading-relaxed mt-1">
            {item.desc}
          </p>
        </div>

        {/* 底部装饰条 */}
        <div class="h-0.5 w-full" style={`background: ${item.accent}`}></div>
      </div>
    ))}
  </div>

  <!-- ====== 底部提示 ====== -->
  <section class="border-t border-zinc-800/50 pt-8 pb-12">
    <div class="text-center text-xs text-zinc-600 space-y-1">
      <p>以上装备均为实际使用产品，持续更新中</p>
      <p>© {new Date().getFullYear()} LiuForge · Gear List</p>
    </div>
  </section>
</BaseLayout>
