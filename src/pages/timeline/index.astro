---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { timeline } from '@/data/profile';
---

<BaseLayout title="时间线 / 经历" description="LiuForge 的经历时间线">
  <section class="mb-10">
    <p class="text-sm font-semibold text-primary">Timeline</p>
    <h1 class="mt-2 text-4xl font-black text-white">时间线 / 经历</h1>
  </section>
  <div class="glass rounded-2xl p-6">
    <div class="space-y-8">
      {timeline.map((item) => (
        <article class="relative border-l border-primary/40 pl-6">
          <span class="absolute -left-2 top-1 h-4 w-4 rounded-full bg-primary shadow-lg shadow-primary/30"></span>
          <time class="text-sm font-bold text-primary">{item.year}</time>
          <h2 class="mt-2 text-xl font-extrabold text-white">{item.title}</h2>
          <p class="mt-2 max-w-2xl text-zinc-400">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
