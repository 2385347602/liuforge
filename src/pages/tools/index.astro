---
// 工具集总览页 - 展示所有工具卡片
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ToolCard from '@/components/tools/ToolCard.astro';

const tools = [
  {
    title: 'JSON Formatter',
    icon: '🔧',
    description: 'JSON 格式化、压缩、校验、复制。粘贴即用，支持错误定位。',
    href: '/tools/json-formatter',
  },
  {
    title: 'Base64 编码/解码',
    icon: '🔐',
    description: '文本与 Base64 字符串互转，支持实时预览和双向切换。',
    href: '/tools/base64',
  },
  {
    title: '时间戳转换',
    icon: '⏰',
    description: 'Unix 时间戳与日期字符串互转，实时显示当前时间戳。',
    href: '/tools/timestamp',
  },
  {
    title: '家庭资产负债表',
    icon: '💰',
    description: '管理资产和负债，自动计算净资产与应急金覆盖率。数据本地存储。',
    href: '/tools/balance-sheet',
  },
  {
    title: '4%法则退休计算器',
    icon: '📈',
    description: '基于年支出×25的退休目标，反推每年需积累金额，情景分析。',
    href: '/tools/retirement-calc',
  },
  {
    title: '21天习惯追踪器',
    icon: '🎯',
    description: '一次培养一个习惯，21天打卡网格，连续天数统计，多轮历史。',
    href: '/tools/habit-tracker',
  },
  {
    title: '周复盘模板',
    icon: '📋',
    description: '每周五20分钟复盘：做对什么、做错什么、下周改一件事。导出 Markdown。',
    href: '/tools/weekly-review',
  },
  {
    title: '投资风险评估',
    icon: '⚠️',
    description: '持仓集中度检测，30%警戒线，全亏影响测试，自定义投资铁律。',
    href: '/tools/investment-risk',
  },
  {
    title: '欲望清理清单',
    icon: '🛒',
    description: '记录每次"想要"，按季度回顾，看冲动率多高。区分想要和需要。',
    href: '/tools/desire-list',
  },
  {
    title: '需求验证记录器',
    icon: '🔍',
    description: '创业想法需求验证，记录用户访谈，统计付费意愿。先验证再写代码。',
    href: '/tools/market-validation',
  },
];
---

<BaseLayout
  title="工具集"
  description="实用在线开发工具集合"
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-2">工具集</h1>
    <p class="text-zinc-500">实用的在线开发工具，所有计算均在浏览器本地完成。</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard
        title={tool.title}
        icon={tool.icon}
        description={tool.description}
        href={tool.href}
      />
    ))}
  </div>
</BaseLayout>
