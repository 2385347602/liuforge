---
// 工具集总览页 - 展示所有工具卡片
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ToolCard from '@/components/tools/ToolCard.astro';

const tools = [
  {
    title: 'JSON Formatter',
    icon: '🔧',
    description: 'JSON 格式化、压缩、校验、复制。粘贴即用，支持错误定位。',
    href: '/tools/json-formatter',
  },
  {
    title: 'Base64 编码/解码',
    icon: '🔐',
    description: '文本与 Base64 字符串互转，支持实时预览和双向切换。',
    href: '/tools/base64',
  },
  {
    title: '时间戳转换',
    icon: '⏰',
    description: 'Unix 时间戳与日期字符串互转，实时显示当前时间戳。',
    href: '/tools/timestamp',
  },
];
---

<BaseLayout
  title="工具集"
  description="实用在线开发工具集合"
>
  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-2">工具集</h1>
    <p class="text-zinc-500">实用的在线开发工具，所有计算均在浏览器本地完成。</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {tools.map((tool) => (
      <ToolCard
        title={tool.title}
        icon={tool.icon}
        description={tool.description}
        href={tool.href}
      />
    ))}
  </div>
</BaseLayout>
