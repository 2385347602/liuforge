---
// JSON Formatter 工具页面
import BaseLayout from '@/components/layout/BaseLayout.astro';
import JsonFormatter from '@/components/tools/JsonFormatter.vue';
---

<BaseLayout
  title="JSON Formatter"
  description="在线 JSON 格式化、压缩、校验工具"
>
  <!-- 面包屑 -->
  <nav class="flex items-center gap-2 text-sm text-zinc-500 mb-8">
    <a href="/tools" class="hover:text-zinc-300 transition-colors">工具集</a>
    <span>/</span>
    <span class="text-zinc-300">JSON Formatter</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-2">JSON Formatter</h1>
    <p class="text-zinc-500">格式化、压缩、校验 JSON 数据。所有处理在浏览器本地完成，不会上传数据。</p>
  </div>

  <div class="rounded-2xl bg-bg-card border border-zinc-800 p-6">
    <JsonFormatter client:load />
  </div>
</BaseLayout>
