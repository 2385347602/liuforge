---
// 时间戳工具页面
import BaseLayout from '@/components/layout/BaseLayout.astro';
import TimestampTool from '@/components/tools/TimestampTool.vue';
---

<BaseLayout
  title="时间戳转换"
  description="Unix 时间戳与日期字符串在线互转"
>
  <!-- 面包屑 -->
  <nav class="flex items-center gap-2 text-sm text-zinc-500 mb-8">
    <a href="/tools" class="hover:text-zinc-300 transition-colors">工具集</a>
    <span>/</span>
    <span class="text-zinc-300">时间戳转换</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-2">时间戳转换</h1>
    <p class="text-zinc-500">Unix 时间戳与日期字符串互转，实时显示当前时间戳。支持秒和毫秒级别。</p>
  </div>

  <div class="rounded-2xl bg-bg-card border border-zinc-800 p-6">
    <TimestampTool client:load />
  </div>
</BaseLayout>
