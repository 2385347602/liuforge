---
// 博客详情页 - MDX 渲染 + TOC 侧边栏
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    // 去掉 .mdx 后缀，使 URL 更干净
    params: { slug: post.id.replace(/\.mdx$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, tags, description, cover } = post.data;
const { Content, headings } = await post.render();

// 筛选 h2/h3 作为目录
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={title} description={description}>
  <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-10">
    <!-- 文章主体 -->
    <article class="prose-custom max-w-none">
      <!-- 头部元信息 -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag: string) => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag)}`}
              class="px-2.5 py-1 rounded-md bg-primary/10 text-primary text-xs font-medium hover:bg-primary/20 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-4 leading-tight">
          {title}
        </h1>
        <div class="flex items-center gap-4 text-sm text-zinc-500">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="text-zinc-700">·</span>
          <span>{post.body?.length ? Math.ceil(post.body.length / 500) : 1} 分钟阅读</span>
        </div>
      </header>

      <!-- 封面图 -->
      {cover && (
        <img
          src={cover}
          alt={title}
          class="w-full rounded-2xl mb-10 border border-zinc-800"
          loading="eager"
        />
      )}

      <!-- 正文内容 -->
      <div class="prose-body">
        <Content />
      </div>
    </article>

    <!-- 侧边栏 TOC -->
    {toc.length > 0 && (
      <aside class="hidden lg:block">
        <nav class="sticky top-24">
          <h4 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4">
            目录
          </h4>
          <ul class="space-y-2 border-l border-zinc-800">
            {toc.map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  class={`block py-1 text-sm transition-colors hover:text-primary ${
                    heading.depth === 3
                      ? 'pl-6 text-zinc-500'
                      : 'pl-4 text-zinc-400'
                  }`}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .prose-body {
    color: #d4d4d8;
    line-height: 1.75;
  }
  .prose-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f4f4f5;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #27272a;
  }
  .prose-body :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #f4f4f5;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-body :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  .prose-body :global(ul),
  .prose-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-body :global(ul > li) {
    list-style: disc;
  }
  .prose-body :global(ol > li) {
    list-style: decimal;
  }
  .prose-body :global(li) {
    color: #d4d4d8;
  }
  .prose-body :global(a) {
    color: #6EE7B7;
  }
  .prose-body :global(a:hover) {
    text-decoration: underline;
  }
  .prose-body :global(blockquote) {
    border-left: 2px solid #6EE7B7;
    padding-left: 1rem;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
    margin: 1rem 0;
    color: #a1a1aa;
    font-style: italic;
  }
  .prose-body :global(img) {
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }
  .prose-body :global(hr) {
    border-color: #27272a;
    margin: 2rem 0;
  }
  .prose-body :global(pre) {
    margin: 1.5rem 0;
  }
  .prose-body :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  .prose-body :global(th) {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 1px solid #3f3f46;
    font-weight: 600;
    color: #e4e4e7;
  }
  .prose-body :global(td) {
    padding: 0.5rem;
    border-bottom: 1px solid #27272a;
    color: #a1a1aa;
  }
</style>
