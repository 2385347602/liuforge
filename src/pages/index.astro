---
// 首页 - LiuForge 入口
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const recentPosts = posts.slice(0, 3);
---

<BaseLayout title="LiuForge" description="LiuForge - 个人网站，分享技术与工具">
  <!-- Hero 区域 -->
  <section class="py-16 sm:py-24 text-center">
    <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight mb-6">
      <span class="bg-gradient-to-r from-primary via-primary-light to-primary bg-clip-text text-transparent">
        LiuForge
      </span>
    </h1>
    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      一个开发者的数字花园，分享技术博客、实用工具和精选排行榜。<br/>
      用代码铸造（Forge）更好的数字体验。
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href="/blog"
        class="px-6 py-3 rounded-xl bg-primary text-black font-semibold text-sm hover:bg-primary-dark transition-colors shadow-lg shadow-primary/20"
      >
        阅读博客
      </a>
      <a
        href="/tools"
        class="px-6 py-3 rounded-xl bg-zinc-800 text-zinc-200 font-semibold text-sm hover:bg-zinc-700 transition-colors border border-zinc-700"
      >
        使用工具
      </a>
      <a
        href="/rankings"
        class="px-6 py-3 rounded-xl bg-zinc-800 text-zinc-200 font-semibold text-sm hover:bg-zinc-700 transition-colors border border-zinc-700"
      >
        查看排行
      </a>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-zinc-100">最新文章</h2>
      <a href="/blog" class="text-sm text-primary hover:underline">
        查看全部 →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {recentPosts.map((post) => (
        <a
          href={`/blog/${post.id.replace(/\.mdx$/, '')}`}
          class="block group p-5 rounded-2xl bg-bg-card border border-zinc-800 hover:border-primary/30 hover:bg-bg-card-hover transition-all duration-300"
        >
          <div class="flex flex-wrap gap-1.5 mb-3">
            {post.data.tags.map((tag: string) => (
              <span class="px-2 py-0.5 rounded-md bg-primary/10 text-primary text-xs font-medium">
                {tag}
              </span>
            ))}
          </div>
          <h3 class="font-semibold text-zinc-100 group-hover:text-primary transition-colors mb-2">
            {post.data.title}
          </h3>
          <p class="text-zinc-400 text-sm line-clamp-2 mb-3">
            {post.data.description}
          </p>
          <time datetime={post.data.date.toISOString()} class="text-zinc-500 text-xs">
            {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </section>

  <!-- 快速导航 -->
  <section class="grid gap-4 sm:grid-cols-3 mb-16">
    <a
      href="/blog"
      class="group p-6 rounded-2xl bg-bg-card border border-zinc-800 hover:border-primary/30 hover:bg-bg-card-hover transition-all duration-300 text-center"
    >
      <div class="text-3xl mb-3">📝</div>
      <h3 class="font-semibold text-zinc-100 group-hover:text-primary transition-colors mb-1">博客</h3>
      <p class="text-zinc-500 text-sm">技术文章与思考</p>
    </a>
    <a
      href="/tools"
      class="group p-6 rounded-2xl bg-bg-card border border-zinc-800 hover:border-primary/30 hover:bg-bg-card-hover transition-all duration-300 text-center"
    >
      <div class="text-3xl mb-3">🛠️</div>
      <h3 class="font-semibold text-zinc-100 group-hover:text-primary transition-colors mb-1">工具集</h3>
      <p class="text-zinc-500 text-sm">实用在线工具</p>
    </a>
    <a
      href="/rankings"
      class="group p-6 rounded-2xl bg-bg-card border border-zinc-800 hover:border-primary/30 hover:bg-bg-card-hover transition-all duration-300 text-center"
    >
      <div class="text-3xl mb-3">🏆</div>
      <h3 class="font-semibold text-zinc-100 group-hover:text-primary transition-colors mb-1">排行榜</h3>
      <p class="text-zinc-500 text-sm">精选工具排行</p>
    </a>
  </section>
</BaseLayout>
