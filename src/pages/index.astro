---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { profile, projects, techStack, timeline } from '@/data/profile';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);
const stats = [
  { label: '文章', value: posts.length.toString() },
  { label: '项目', value: projects.length.toString().padStart(2, '0') },
  { label: '标签', value: [...new Set(posts.flatMap((post) => post.data.tags))].length.toString() },
  { label: '在线', value: '24/7' },
];
---

<BaseLayout title="个人品牌主页" description="LiuForge 的个人品牌主页、项目展示、文章与数字工作台" fullWidth>
  <section class="relative min-h-[calc(100vh-4rem)] overflow-hidden px-4 py-10 sm:px-6 lg:px-8">
    <div class="absolute inset-0 -z-10">
      <div class="h-full w-full bg-[radial-gradient(circle_at_30%_20%,rgba(110,231,183,.28),transparent_30%),radial-gradient(circle_at_70%_35%,rgba(56,189,248,.22),transparent_34%),linear-gradient(135deg,#050505,#101014_45%,#050505)]"></div>
      <div class="absolute inset-0 opacity-35 mix-blend-screen" style="background-image: linear-gradient(120deg, transparent 0 35%, rgba(255,255,255,.22) 45%, transparent 55% 100%);"></div>
    </div>
    <div class="particle-field" aria-hidden="true">
      {Array.from({ length: 34 }).map((_, index) => (
        <span style={`left:${(index * 29) % 100}%; bottom:${(index * 17) % 90}%; animation-delay:${index * -0.31}s; animation-duration:${8 + (index % 7)}s;`}></span>
      ))}
    </div>

    <div class="mx-auto grid max-w-7xl items-center gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="pt-8 sm:pt-16">
        <p class="mb-5 inline-flex rounded-lg border border-white/15 bg-white/8 px-3 py-1.5 text-sm text-zinc-300 backdrop-blur-xl">
          {profile.status}
        </p>
        <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-normal text-white sm:text-7xl lg:text-8xl">
          <span class="block">记住</span>
          <span class="typewriter bg-gradient-to-r from-primary-light via-cyan-200 to-fuchsia-200 bg-clip-text text-transparent">LiuForge</span>
        </h1>
        <p class="mt-7 max-w-2xl text-base leading-8 text-zinc-300 sm:text-lg">
          {profile.headline}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/blog" class="rounded-lg bg-primary px-5 py-3 text-sm font-bold text-black shadow-lg shadow-primary/20 transition-transform hover:-translate-y-0.5">看文章</a>
          <a href="/projects" class="rounded-lg border border-white/15 bg-white/10 px-5 py-3 text-sm font-bold text-white backdrop-blur-xl transition-transform hover:-translate-y-0.5">看项目</a>
          <a href={`mailto:${profile.email}`} class="rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-bold text-zinc-200 transition-transform hover:-translate-y-0.5">联系你</a>
          <a href={profile.resumeUrl} class="rounded-lg border border-white/15 bg-black/20 px-5 py-3 text-sm font-bold text-zinc-200 transition-transform hover:-translate-y-0.5">下载简历</a>
        </div>
      </div>

      <div class="grid gap-4 lg:pt-8">
        <div class="glass-strong rounded-2xl p-5">
          <div class="mb-4 flex items-center justify-between">
            <div>
              <p class="text-sm text-zinc-400">Dashboard</p>
              <h2 class="text-2xl font-extrabold text-white">数字工作台</h2>
            </div>
            <div class="audio-bars flex h-10 items-end gap-1.5">
              {Array.from({ length: 9 }).map((_, index) => (
                <span style={`animation-delay:${index * 80}ms; height:${30 + (index % 5) * 12}%`}></span>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            {stats.map((stat) => (
              <div class="rounded-xl border border-white/10 bg-black/25 p-4">
                <div class="text-3xl font-black text-white">{stat.value}</div>
                <div class="mt-1 text-xs text-zinc-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="glass rounded-2xl p-5">
            <p class="text-sm text-zinc-400">GitHub 数据</p>
            <div class="mt-4 grid grid-cols-7 gap-1">
              {Array.from({ length: 49 }).map((_, index) => (
                <span class={`h-4 rounded-sm ${index % 9 === 0 ? 'bg-primary' : index % 4 === 0 ? 'bg-cyan-400/70' : index % 3 === 0 ? 'bg-white/20' : 'bg-white/8'}`}></span>
              ))}
            </div>
          </div>
          <div class="glass rounded-2xl p-5">
            <p class="text-sm text-zinc-400">正在做的事</p>
            <ul class="mt-4 space-y-3 text-sm text-zinc-200">
              <li>AI 工作流产品化</li>
              <li>个人知识库公开化</li>
              <li>每周输出一篇文章</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-primary">Featured Projects</p>
        <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">3D 项目卡片</h2>
      </div>
      <a href="/projects" class="text-sm font-semibold text-zinc-300 hover:text-primary">查看全部</a>
    </div>
    <div class="grid gap-5 lg:grid-cols-3">
      {projects.map((project) => (
        <a href="/projects" class="project-3d glass block rounded-2xl p-5">
          <div class={`mb-5 h-36 rounded-xl bg-gradient-to-br ${project.gradient} opacity-90`}></div>
          <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400">{project.type}</p>
          <h3 class="mt-2 text-xl font-extrabold text-white">{project.title}</h3>
          <p class="mt-3 text-sm leading-6 text-zinc-400">{project.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="rounded-md bg-white/10 px-2 py-1 text-xs text-zinc-300">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-5 px-4 pb-16 sm:px-6 lg:grid-cols-[1fr_0.9fr] lg:px-8">
    <div class="glass rounded-2xl p-6">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-2xl font-black text-white">最近文章</h2>
        <a href="/blog" class="text-sm text-primary">看文章</a>
      </div>
      <div class="space-y-3">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.mdx$/, '')}`} class="block rounded-xl border border-white/10 bg-white/5 p-4 transition-colors hover:bg-white/10">
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-bold text-white">{post.data.title}</h3>
              <span class="shrink-0 text-xs text-zinc-500">{Math.ceil((post.body?.length || 300) / 500)} 分钟</span>
            </div>
            <p class="mt-2 line-clamp-2 text-sm text-zinc-400">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
    <div class="grid gap-5">
      <div class="glass rounded-2xl p-6">
        <h2 class="text-2xl font-black text-white">技术栈</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {techStack.map((tech) => <span class="rounded-lg border border-white/10 bg-white/8 px-3 py-2 text-sm text-zinc-200">{tech}</span>)}
        </div>
      </div>
      <div class="glass rounded-2xl p-6">
        <h2 class="text-2xl font-black text-white">时间线</h2>
        <div class="mt-5 space-y-4">
          {timeline.slice(0, 2).map((item) => (
            <div class="border-l border-primary/40 pl-4">
              <div class="text-xs font-bold text-primary">{item.year}</div>
              <div class="font-bold text-white">{item.title}</div>
              <p class="mt-1 text-sm text-zinc-400">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
