---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { projects, text } from '@/data/profile';
---

<BaseLayout title="项目作品" description="LiuForge 的作品集和项目展示">
  <section class="mb-10">
    <p class="text-sm font-semibold text-primary">Portfolio</p>
    <h1 class="mt-2 text-4xl font-black text-white">项目作品</h1>
    <p class="mt-3 max-w-2xl text-zinc-400">
      面向真实问题的产品原型、工程实践和个人品牌资产。
    </p>
  </section>
  <div class="grid gap-5 lg:grid-cols-3">
    {projects.map((project) => (
      <article class="project-3d glass rounded-2xl p-5">
        <div class={`h-44 rounded-xl bg-gradient-to-br ${project.gradient}`}></div>
        <p class="mt-5 text-xs font-semibold uppercase tracking-widest text-zinc-500">{text(project.type)}</p>
        <h2 class="mt-2 text-2xl font-extrabold text-white">{project.title}</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-400">{text(project.description)}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {project.tags.map((tag) => <span class="rounded-md bg-primary/10 px-2 py-1 text-xs text-primary">{tag}</span>)}
        </div>
        <div class="mt-6 rounded-xl border border-white/10 bg-white/5 p-4 text-sm text-zinc-300">{text(project.impact)}</div>
      </article>
    ))}
  </div>
</BaseLayout>
