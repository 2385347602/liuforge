---
import { getCollection } from 'astro:content';
import HeroBackdrop from './HeroBackdrop.astro';
import { profile, projects, techStack, text, timeline, type Language } from '@/data/profile';

interface Props {
  lang?: Language;
}

const { lang = 'zh' } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);
const fallbackPostCount = posts.length || (await getCollection('blog')).filter((post) => !post.data.draft).length;
const stats = [
  { label: lang === 'zh' ? '文章' : 'Posts', value: fallbackPostCount.toString() },
  { label: lang === 'zh' ? '项目' : 'Projects', value: projects.length.toString().padStart(2, '0') },
  { label: lang === 'zh' ? '标签' : 'Tags', value: [...new Set(posts.flatMap((post) => post.data.tags))].length.toString() },
  { label: lang === 'zh' ? '在线' : 'Online', value: '24/7' },
];

const copy = {
  remember: lang === 'zh' ? '记住' : 'Remember',
  read: lang === 'zh' ? '看文章' : 'Read Writing',
  projects: lang === 'zh' ? '看项目' : 'View Projects',
  contact: lang === 'zh' ? '联系我' : 'Contact',
  resume: lang === 'zh' ? '下载简历' : 'Resume',
  dashboard: lang === 'zh' ? '数字工作台' : 'Digital Workspace',
  github: lang === 'zh' ? 'GitHub 数据' : 'GitHub Activity',
  now: lang === 'zh' ? '正在做的事' : 'Now Building',
  nowItems: lang === 'zh'
    ? ['AI 工作流产品化', '个人知识库公开化', '每周输出一篇文章']
    : ['Productizing AI workflows', 'Publishing a personal knowledge base', 'Writing one essay every week'],
  featured: lang === 'zh' ? '3D 项目卡片' : '3D Project Cards',
  viewAll: lang === 'zh' ? '查看全部' : 'View All',
  recent: lang === 'zh' ? '最近文章' : 'Recent Writing',
  minutes: lang === 'zh' ? '分钟' : 'min',
  tech: lang === 'zh' ? '技术栈' : 'Tech Stack',
  timeline: lang === 'zh' ? '时间线' : 'Timeline',
  emptyPosts: lang === 'zh' ? '英文文章正在整理中，先看看项目和时间线。' : 'English posts are being prepared. Explore projects and the timeline for now.',
};
---

<section class="relative min-h-[calc(100vh-4rem)] overflow-hidden px-4 py-10 sm:px-6 lg:px-8">
  <HeroBackdrop />
  <div class="particle-field" aria-hidden="true">
    {Array.from({ length: 34 }).map((_, index) => (
      <span style={`left:${(index * 29) % 100}%; bottom:${(index * 17) % 90}%; animation-delay:${index * -0.31}s; animation-duration:${8 + (index % 7)}s;`}></span>
    ))}
  </div>

  <div class="mx-auto grid max-w-7xl items-center gap-6 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="pt-8 sm:pt-16">
      <p class="mb-5 inline-flex rounded-lg border border-white/15 bg-white/8 px-3 py-1.5 text-sm text-zinc-300 backdrop-blur-xl">
        {text(profile.status, lang)}
      </p>
      <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-normal text-white sm:text-7xl lg:text-8xl">
        <span class="block">{copy.remember}</span>
        <span class="typewriter bg-gradient-to-r from-primary-light via-cyan-200 to-fuchsia-200 bg-clip-text text-transparent">LiuForge</span>
      </h1>
      <p class="mt-7 max-w-2xl text-base leading-8 text-zinc-300 sm:text-lg">
        {text(profile.headline, lang)}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog" class="rounded-lg bg-primary px-5 py-3 text-sm font-bold text-black shadow-lg shadow-primary/20 transition-transform hover:-translate-y-0.5">{copy.read}</a>
        <a href="/projects" class="rounded-lg border border-white/15 bg-white/10 px-5 py-3 text-sm font-bold text-white backdrop-blur-xl transition-transform hover:-translate-y-0.5">{copy.projects}</a>
        <a href={`mailto:${profile.email}`} class="rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-bold text-zinc-200 transition-transform hover:-translate-y-0.5">{copy.contact}</a>
        <a href={profile.resumeUrl} class="rounded-lg border border-white/15 bg-black/20 px-5 py-3 text-sm font-bold text-zinc-200 transition-transform hover:-translate-y-0.5">{copy.resume}</a>
      </div>
    </div>

    <div class="grid gap-4 lg:pt-8">
      <div class="glass-strong rounded-2xl p-5">
        <div class="mb-4 flex items-center justify-between">
          <div>
            <p class="text-sm text-zinc-400">Dashboard</p>
            <h2 class="text-2xl font-extrabold text-white">{copy.dashboard}</h2>
          </div>
          <div class="audio-bars flex h-10 items-end gap-1.5">
            {Array.from({ length: 9 }).map((_, index) => (
              <span style={`animation-delay:${index * 80}ms; height:${30 + (index % 5) * 12}%`}></span>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {stats.map((stat) => (
            <div class="rounded-xl border border-white/10 bg-black/25 p-4">
              <div class="text-3xl font-black text-white">{stat.value}</div>
              <div class="mt-1 text-xs text-zinc-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="glass rounded-2xl p-5">
          <p class="text-sm text-zinc-400">{copy.github}</p>
          <div class="mt-4 grid grid-cols-7 gap-1">
            {Array.from({ length: 49 }).map((_, index) => (
              <span class={`h-4 rounded-sm ${index % 9 === 0 ? 'bg-primary' : index % 4 === 0 ? 'bg-cyan-400/70' : index % 3 === 0 ? 'bg-white/20' : 'bg-white/8'}`}></span>
            ))}
          </div>
        </div>
        <div class="glass rounded-2xl p-5">
          <p class="text-sm text-zinc-400">{copy.now}</p>
          <ul class="mt-4 space-y-3 text-sm text-zinc-200">
            {copy.nowItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <p class="text-sm font-semibold text-primary">Featured Projects</p>
      <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">{copy.featured}</h2>
    </div>
    <a href="/projects" class="text-sm font-semibold text-zinc-300 hover:text-primary">{copy.viewAll}</a>
  </div>
  <div class="grid gap-5 lg:grid-cols-3">
    {projects.map((project) => (
      <a href="/projects" class="project-3d glass block rounded-2xl p-5">
        <div class={`mb-5 h-36 rounded-xl bg-gradient-to-br ${project.gradient} opacity-90`}></div>
        <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400">{text(project.type, lang)}</p>
        <h3 class="mt-2 text-xl font-extrabold text-white">{project.title}</h3>
        <p class="mt-3 text-sm leading-6 text-zinc-400">{text(project.description, lang)}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {project.tags.map((tag) => <span class="rounded-md bg-white/10 px-2 py-1 text-xs text-zinc-300">{tag}</span>)}
        </div>
      </a>
    ))}
  </div>
</section>

<section class="mx-auto grid max-w-7xl gap-5 px-4 pb-16 sm:px-6 lg:grid-cols-[1fr_0.9fr] lg:px-8">
  <div class="glass rounded-2xl p-6">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-2xl font-black text-white">{copy.recent}</h2>
      <a href="/blog" class="text-sm text-primary">{copy.read}</a>
    </div>
    <div class="space-y-3">
      {recentPosts.length > 0 ? recentPosts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.mdx$/, '')}`} class="block rounded-xl border border-white/10 bg-white/5 p-4 transition-colors hover:bg-white/10">
          <div class="flex items-center justify-between gap-4">
            <h3 class="font-bold text-white">{post.data.title}</h3>
            <span class="shrink-0 text-xs text-zinc-500">{Math.ceil((post.body?.length || 300) / 500)} {copy.minutes}</span>
          </div>
          <p class="mt-2 line-clamp-2 text-sm text-zinc-400">{post.data.description}</p>
        </a>
      )) : (
        <p class="rounded-xl border border-white/10 bg-white/5 p-4 text-sm text-zinc-400">{copy.emptyPosts}</p>
      )}
    </div>
  </div>
  <div class="grid gap-5">
    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-black text-white">{copy.tech}</h2>
      <div class="mt-5 flex flex-wrap gap-2">
        {techStack.map((tech) => <span class="rounded-lg border border-white/10 bg-white/8 px-3 py-2 text-sm text-zinc-200">{tech}</span>)}
      </div>
    </div>
    <div class="glass rounded-2xl p-6">
      <h2 class="text-2xl font-black text-white">{copy.timeline}</h2>
      <div class="mt-5 space-y-4">
        {timeline.slice(0, 2).map((item) => (
          <div class="border-l border-primary/40 pl-4">
            <div class="text-xs font-bold text-primary">{item.year}</div>
            <div class="font-bold text-white">{text(item.title, lang)}</div>
            <p class="mt-1 text-sm text-zinc-400">{text(item.description, lang)}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
