---
// 博客文章卡片 - 用于列表页展示
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, tags, description } = post.data;
// 去掉 .mdx 后缀作为 URL slug
const slug = post.id.replace(/\.mdx$/, '');
---

<a
  href={`/blog/${slug}`}
  class="block group p-6 rounded-2xl bg-bg-card border border-zinc-800 hover:border-primary/30 hover:bg-bg-card-hover transition-all duration-300"
>
  <!-- 标签 -->
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag: string) => (
      <span class="px-2 py-0.5 rounded-md bg-primary/10 text-primary text-xs font-medium">
        {tag}
      </span>
    ))}
  </div>

  <!-- 标题 -->
  <h3 class="text-lg font-semibold text-zinc-100 group-hover:text-primary transition-colors mb-2">
    {title}
  </h3>

  <!-- 摘要 -->
  <p class="text-zinc-400 text-sm leading-relaxed mb-4 line-clamp-2">
    {description}
  </p>

  <!-- 日期 -->
  <time datetime={date.toISOString()} class="text-zinc-500 text-xs">
    {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
  </time>
</a>
