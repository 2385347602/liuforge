---
import PostCard from './PostCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  activeTag?: string;
  allTags: string[];
}

const { posts, activeTag, allTags } = Astro.props;
---

<div class="mb-8 flex flex-wrap gap-2">
  <a
    href="/blog"
    class={`rounded-lg px-3 py-1.5 text-sm font-semibold transition-all ${
      !activeTag ? 'bg-primary text-black shadow-lg shadow-primary/20' : 'bg-white/8 text-zinc-400 hover:text-zinc-100'
    }`}
  >
    全部
  </a>
  {allTags.map((tag: string) => {
    const isActive = activeTag === tag;
    return (
      <a
        href={isActive ? '/blog' : `/blog?tag=${encodeURIComponent(tag)}`}
        class={`rounded-lg px-3 py-1.5 text-sm font-semibold transition-all ${
          isActive ? 'bg-primary text-black shadow-lg shadow-primary/20' : 'bg-white/8 text-zinc-400 hover:text-zinc-100'
        }`}
      >
        {tag}
      </a>
    );
  })}
</div>

{posts.length === 0 ? (
  <div class="glass rounded-2xl py-20 text-center text-zinc-500">暂无该标签的文章</div>
) : (
  <div class="grid gap-4 sm:grid-cols-2">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
)}
