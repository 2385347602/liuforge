---
// 顶部导航栏 - Logo + 导航链接 + 暗色模式
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '博客' },
  { href: '/tools', label: '工具集' },
  { href: '/rankings', label: '排行榜' },
  { href: '/about', label: '关于' },
  { href: '/gear', label: '装备' },
];
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-bg-dark/80 border-b border-zinc-800/50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl tracking-tight hover:opacity-80 transition-opacity">
      <span class="text-primary text-2xl">&gt;</span>
      <span class="bg-gradient-to-r from-primary to-primary-light bg-clip-text text-transparent">
        LiuForge
      </span>
    </a>

    <!-- 导航链接 - 桌面端 -->
    <div class="hidden sm:flex items-center gap-1">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                isActive
                  ? 'text-primary bg-primary/10'
                  : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/50'
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <!-- 移动端汉堡菜单按钮 -->
    <button
      id="mobile-menu-btn"
      class="sm:hidden p-2 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800"
      aria-label="打开菜单"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="6" y2="6" />
        <line x1="4" x2="20" y1="12" y2="12" />
        <line x1="4" x2="20" y1="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- 移动端下拉菜单 -->
  <div
    id="mobile-menu"
    class="sm:hidden hidden border-t border-zinc-800 bg-bg-dark/95 backdrop-blur-md"
  >
    <div class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              isActive
                ? 'text-primary bg-primary/10'
                : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/50'
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  // 移动端菜单切换
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
